        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "为每个小组件选择主页、额度、模型、活动或趋势。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "為每個小工具選擇主頁、額度、模型、活動或趨勢。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ウィジェットごとに概要、クォータ、モデル、アクティビティ、トレンドを選択します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "각 위젯에서 개요, 할당량, 모델, 활동 또는 추세를 선택합니다."
          }
